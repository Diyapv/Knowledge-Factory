# ─── Azure AD / Microsoft Entra SSO Configuration ─────────────
# To enable Microsoft SSO, register an app in Azure Portal:
# 1. Go to https://portal.azure.com
# 2. Azure Active Directory → App registrations → New registration
# 3. Name: "Knowledge Factory", Platform: SPA
# 4. Redirect URI: http://localhost:5173 (dev) or your production URL
# 5. Copy the values below from your app registration

# Client (frontend) — used by the React app
VITE_AZURE_CLIENT_ID=your-application-client-id
VITE_AZURE_TENANT_ID=your-directory-tenant-id
VITE_AZURE_REDIRECT_URI=http://localhost:5173

# Server — used for token validation (same values)
AZURE_CLIENT_ID=your-application-client-id
AZURE_TENANT_ID=your-directory-tenant-id

# ─── Notes ─────────────────────────────────────────────────────
# - Leave VITE_AZURE_CLIENT_ID as-is or unset to disable SSO
#   (the "Sign in with Microsoft" button won't appear)
# - Local username/password login always works regardless of SSO config
# - SSO users are assigned "member" role by default
# - If an SSO user's email prefix matches a local username,
#   they inherit that user's role (e.g., admin)
